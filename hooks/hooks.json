{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_fidelity.sh\"", "timeout": 120 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_verifier.sh\"", "timeout": 180 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_mutation.sh\"", "timeout": 600 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_artifact_check.sh\"", "timeout": 30 }
        ]
      }
    ]
  }
}